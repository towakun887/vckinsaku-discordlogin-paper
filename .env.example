# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here
ADMIN_ROLE_ID=your_admin_role_id_here

# Plugin API Configuration
PLUGIN_API_URL=http://localhost:25580
PLUGIN_API_KEY=your_shared_api_key_here
BOT_TEST_MODE=false

# Server Connection Info
# Java is address only (default port 25565, or specify it as address:port)
JAVA_SERVER_ADDRESS=your_java_server_address_here
BEDROCK_SERVER_ADDRESS=your_bedrock_server_address_here
BEDROCK_SERVER_PORT=19132
